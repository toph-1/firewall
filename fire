#!/bin/bash

# ===========================
# OPENVPN IP ROTATOR (SAFE)
# ===========================

VPN_CONFIG="/path/to/your/config.ovpn"
INTERVAL=60   # seconds (don’t go too low)

if [ "$EUID" -ne 0 ]; then
    echo "Run as root: sudo $0"
    exit 1
fi

while true; do
    echo "🔄 Restarting OpenVPN..."

    # Kill existing OpenVPN
    pkill openvpn 2>/dev/null
    sleep 3

    # Start OpenVPN in background
    openvpn --config "$VPN_CONFIG" --daemon

    # Wait for connection to establish
    sleep 10

    # Show new IP
    echo "🌐 Current public IP:"
    curl -s ifconfig.me
    echo ""

    echo "⏳ Waiting $INTERVAL seconds before next rotation..."
    sleep $INTERVAL
done
