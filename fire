#!/bin/bash

# =========================================
# STRICT FIREWALL + STABLE LAN IP ROTATION (Virtual Interface)
# =========================================

if [ "$EUID" -ne 0 ]; then
    echo "⚠️ Run this as root: sudo $0"
    exit 1
fi

# ===========================
# AUTO-DETECT NETWORK INTERFACE
# ===========================
INTERFACE=$(ip -o -4 route show to default | awk '{print $5}')

if [ -z "$INTERFACE" ]; then
    echo "❌ Could not detect a network interface."
    exit 1
fi

echo "✔️ Detected network interface: $INTERFACE"

# ===========================
# CONFIG
# ===========================
ORIGINAL_IP=$(ip addr show $INTERFACE | grep "inet " | awk '{print $2}')
ORIGINAL_RULES="/etc/nftables.conf.bak.$(date +%F-%T)"
VIRTUAL_INTERFACE="vir0"  # Virtual interface for IP rotation

# ===========================
# BACKUP CURRENT FIREWALL
# ===========================
if [ -f /etc/nftables.conf ]; then
    cp /etc/nftables.conf "$ORIGINAL_RULES"
fi

# ===========================
# APPLY STRICT FIREWALL
# ===========================
apply_firewall() {
    echo "🔒 Applying strict firewall..."
    apt update >/dev/null 2>&1
    apt install -y nftables >/dev/null 2>&1
    systemctl stop nftables

    cat > /etc/nftables.conf << 'EOF'
table inet filter {
    chain input {
        type filter hook input priority 0;
        policy drop;
        iif lo accept
        ct state established,related accept
    }
    chain forward { policy drop; }
    chain output { policy accept; }
}
EOF

    systemctl start nftables
    chown root:root /etc/nftables.conf
    chmod 600 /etc/nftables.conf
    chattr +i /etc/nftables.conf
}

# ===========================
# RESTORE FIREWALL
# ===========================
restore_firewall() {
    echo "🔓 Restoring original firewall..."
    chattr -i /etc/nftables.conf 2>/dev/null
    systemctl stop nftables
    if [ -f "$ORIGINAL_RULES" ]; then
        cp "$ORIGINAL_RULES" /etc/nftables.conf
    fi
    systemctl start nftables
}

# ===========================
# CREATE VIRTUAL INTERFACE FOR IP ROTATION
# ===========================
create_virtual_interface() {
    echo "🌐 Creating virtual network interface $VIRTUAL_INTERFACE..."
    ip link add link "$INTERFACE" name "$VIRTUAL_INTERFACE" type macvlan mode bridge
    ip addr add 192.168.100.100/24 dev "$VIRTUAL_INTERFACE"  # Starting IP for the virtual interface
    ip link set "$VIRTUAL_INTERFACE" up
}

# ===========================
# DYNAMIC IP LOOP (Virtual Interface)
# ===========================
dynamic_ip_loop() {
    echo "🌐 Starting dynamic LAN IP rotation on $VIRTUAL_INTERFACE..."
    trap restore_on_exit SIGINT SIGTERM
    while true; do
        # Generate a random local IP
        NEW_IP="192.168.$((RANDOM%254+1)).$((RANDOM%254+1))/24"
        
        ip addr flush dev "$VIRTUAL_INTERFACE"  # Flush current IP
        ip addr add "$NEW_IP" dev "$VIRTUAL_INTERFACE"  # Set new random IP

        # Wait for a second before changing again
        sleep 1
    done
}

# ===========================
# RESTORE ON EXIT (Remove Virtual Interface)
# ===========================
restore_on_exit() {
    echo "⚠️ Detected stop signal, restoring everything..."
    ip addr flush dev "$VIRTUAL_INTERFACE"  # Remove IP from virtual interface
    ip link set "$VIRTUAL_INTERFACE" down  # Bring the virtual interface down
    ip link delete "$VIRTUAL_INTERFACE"  # Delete the virtual interface
    restore_firewall
    ip addr add "$ORIGINAL_IP" dev "$INTERFACE"  # Restore original IP to main interface
    echo "✅ Everything restored."
    exit 0
}

# ===========================
# MAIN
# ===========================
echo "1) Apply strict firewall + stable dynamic IP rotation"
echo "2) Restore firewall + original IP now"
read -p "Choose: " choice

case $choice in
    1)
        apply_firewall
        create_virtual_interface
        dynamic_ip_loop
        ;;
    2)
        restore_on_exit
        ;;
    *)
        echo "❌ Invalid choice."
        ;;
esac
