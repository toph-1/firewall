#!/bin/bash

# =========================================
# STABLE FIREWALL + SAFE RESTORE + NETWORK SCAN
# =========================================

if [ "$EUID" -ne 0 ]; then
    echo "⚠️ Run as root: sudo $0"
    exit 1
fi

# Detect main interface
INTERFACE=$(ip route | grep default | awk '{print $5}' | head -n1)

if [ -z "$INTERFACE" ]; then
    echo "❌ Could not detect network interface"
    exit 1
fi

echo "✔️ Interface: $INTERFACE"

# Get original IP safely
ORIGINAL_IP=$(ip -4 addr show "$INTERFACE" | grep inet | awk '{print $2}' | head -n1)

if [ -z "$ORIGINAL_IP" ]; then
    echo "❌ Could not detect original IP"
    exit 1
fi

echo "✔️ Original IP: $ORIGINAL_IP"

BACKUP="/etc/nftables.conf.backup"

# Backup firewall
[ -f /etc/nftables.conf ] && cp /etc/nftables.conf "$BACKUP"

# ===========================
# APPLY FIREWALL
# ===========================
apply_firewall() {
    echo "🔒 Applying strict firewall..."

    apt install -y nftables >/dev/null 2>&1

    cat > /etc/nftables.conf << 'EOF'
table inet filter {
    chain input {
        type filter hook input priority 0;
        policy drop;
        iif lo accept
        ct state established,related accept
    }
    chain forward { policy drop; }
    chain output { policy accept; }
}
EOF

    systemctl restart nftables
}

# ===========================
# RESTORE EVERYTHING
# ===========================
restore() {
    echo "🔓 Restoring system..."

    # Restore firewall
    if [ -f "$BACKUP" ]; then
        cp "$BACKUP" /etc/nftables.conf
        systemctl restart nftables
    fi

    # Restore IP (only if missing)
    CURRENT_IP=$(ip -4 addr show "$INTERFACE" | grep inet | awk '{print $2}' | head -n1)

    if [ -z "$CURRENT_IP" ]; then
        ip addr add "$ORIGINAL_IP" dev "$INTERFACE"
    fi

    echo "✅ Restored successfully"
    exit 0
}

trap restore SIGINT SIGTERM

# ===========================
# NETWORK SCAN (LOCAL ONLY)
# ===========================
scan_network() {
    SUBNET=$(ip -4 route | grep "$INTERFACE" | grep src | awk '{print $1}' | head -n1)

    if [ -z "$SUBNET" ]; then
        echo "❌ Could not detect subnet"
        return
    fi

    echo "🔍 Scanning network: $SUBNET"

    apt install -y nmap >/dev/null 2>&1

    nmap -sn "$SUBNET"
}

# ===========================
# MENU
# ===========================
echo "1) Apply strict firewall + scan network"
echo "2) Restore now"
read -p "Choose: " choice

case $choice in
    1)
        apply_firewall
        scan_network
        ;;
    2)
        restore
        ;;
    *)
        echo "❌ Invalid choice"
        ;;
esac
