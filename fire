#!/bin/bash

# ===========================
# SMART FAST VPN ROTATOR
# ===========================

VPN1="/path/to/server1.ovpn"
VPN2="/path/to/server2.ovpn"
HOLD_TIME=3   # how long to stay connected AFTER success

if [ "$EUID" -ne 0 ]; then
    echo "Run as root: sudo $0"
    exit 1
fi

get_ip() {
    curl -s --max-time 5 ifconfig.me
}

wait_for_vpn() {
    echo "⏳ Waiting for VPN to connect..."
    for i in {1..15}; do
        IP=$(get_ip)
        if [[ -n "$IP" ]]; then
            echo "🌐 Connected with IP: $IP"
            return 0
        fi
        sleep 1
    done
    echo "⚠️ VPN connection timeout"
    return 1
}

start_vpn() {
    CONFIG=$1
    echo "🔌 Switching to $CONFIG"

    pkill openvpn 2>/dev/null
    sleep 2

    openvpn --config "$CONFIG" --daemon
}

while true; do
    start_vpn "$VPN1"
    if wait_for_vpn; then
        echo "⏱ Holding for $HOLD_TIME seconds..."
        sleep $HOLD_TIME
    fi

    start_vpn "$VPN2"
    if wait_for_vpn; then
        echo "⏱ Holding for $HOLD_TIME seconds..."
        sleep $HOLD_TIME
    fi
done
